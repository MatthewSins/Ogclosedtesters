generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DEVELOPER
  TESTER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  PAUSED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuthTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model User {
  id                   String           @id @default(cuid())
  name                 String?
  email                String           @unique
  passwordHash         String
  role                 Role             @default(DEVELOPER)
  status               UserStatus       @default(ACTIVE)
  emailVerifiedAt      DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  projects             Project[]        @relation("DeveloperProjects")
  feedback             Feedback[]
  chats                ChatMessage[]
  testerJoins          TesterJoin[]
  joinRequests         JoinRequest[]    @relation("JoinRequestTester")
  reviewedJoinRequests JoinRequest[]    @relation("JoinRequestReviewer")
  authTokens           AuthToken[]
  adminLogs            AdminAudit[]     @relation("AdminAuditActor")
}

model Project {
  id                 String        @id @default(cuid())
  appName            String
  appLink            String
  groupLink          String?
  durationDays       Int           @default(14)
  targetTesters      Int           @default(12)
  testerInstructions String?
  status             ProjectStatus @default(DRAFT)
  startDate          DateTime      @default(now())
  endDate            DateTime
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  developerId        String
  developer          User          @relation("DeveloperProjects", fields: [developerId], references: [id])
  feedback           Feedback[]
  chats              ChatMessage[]
  testerJoins        TesterJoin[]
  joinRequests       JoinRequest[]
}

model JoinRequest {
  id           String            @id @default(cuid())
  testerId     String
  projectId    String
  status       JoinRequestStatus @default(PENDING)
  reason       String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tester       User              @relation("JoinRequestTester", fields: [testerId], references: [id])
  reviewer     User?             @relation("JoinRequestReviewer", fields: [reviewedById], references: [id])
  project      Project           @relation(fields: [projectId], references: [id])

  @@unique([testerId, projectId])
  @@index([projectId, status])
}

model TesterJoin {
  id         String   @id @default(cuid())
  userId     String
  projectId  String
  joinedAt   DateTime @default(now())
  points     Int      @default(0)
  daysActive Int      @default(0)
  rating     Int      @default(5)
  lastActive DateTime?
  user       User     @relation(fields: [userId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model Feedback {
  id             String    @id @default(cuid())
  projectId      String
  userId         String
  text           String
  screenshot     String?
  attachmentUrl  String?
  attachmentType MediaType?
  rating         Int       @default(5)
  createdAt      DateTime  @default(now())
  project        Project   @relation(fields: [projectId], references: [id])
  user           User      @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id             String    @id @default(cuid())
  projectId      String
  userId         String
  content        String
  attachmentUrl  String?
  attachmentType MediaType?
  mentionHandles String[]  @default([])
  createdAt      DateTime  @default(now())
  project        Project   @relation(fields: [projectId], references: [id])
  user           User      @relation(fields: [userId], references: [id])
}

model AuthToken {
  id         String        @id @default(cuid())
  userId     String
  token      String        @unique
  type       AuthTokenType
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id])

  @@index([userId, type])
  @@index([token, type])
}

model AdminAudit {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  payload    Json?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminAuditActor", fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}
